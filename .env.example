APP_NAME=RODS Backend
APP_VERSION=0.1.0

CAMERA_SOURCE_TYPE=usb
CAMERA_SOURCE=0
CAMERA_DEFAULT_USB_INDEX=0
CAMERA_DISCOVERY_MAX_INDEX=5
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

FRAME_JPEG_QUALITY=85
STREAM_BOUNDARY=frame
STREAM_WS_FPS=5

VISION_ENABLED=true
VISION_MODEL_PATH=yolov8n.pt
VISION_CONFIDENCE_THRESHOLD=0.5
VISION_IOU_THRESHOLD=0.45
VISION_MAX_DETECTIONS=100
VISION_INFERENCE_FPS=5
VISION_LOG_INTERVAL_SECONDS=5
VISION_TRACKING_ENABLED=true
VISION_TRACKING_PERSIST=true
VISION_TRACKER_CONFIG=bytetrack.yaml

DATABASE_PATH=data/rods.db
SCREENSHOTS_DIR=data/screenshots
EVENT_STABLE_FRAMES=8
EVENT_ABSENT_FRAMES=12
EVENT_COOLDOWN_SECONDS=30
EVENT_RECENT_LIMIT=100
LIVE_PING_INTERVAL_SECONDS=15
